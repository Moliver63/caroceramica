# Banco de dados (Postgres — Render, Supabase, Neon, etc.)
DATABASE_URL=postgresql://usuario:senha@host:5432/caro_ceramica

# Asaas — gateway de pagamento (fase 1, único ativo)
ASAAS_API_KEY=sua_chave_aqui
ASAAS_ENV=sandbox
# ASAAS_ENV=production

# Porta da API
PORT=4000

# Painel administrativo (/admin) — senha única + segredo de sessão
ADMIN_PASSWORD=defina_uma_senha_forte_aqui
ADMIN_SESSION_SECRET=defina_uma_string_aleatoria_longa_aqui

# Cloudinary — upload de imagens dos produtos
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret

# Reservado para fase 2 — NÃO usar ainda
# STRIPE_SECRET_KEY=
